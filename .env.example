# Default project to index/chat (optional if you pass path via CLI: code chat ./my-app)
PROJECT_PATH=D:\path\to\your\project

# Optional — override user data directory (default: ~/.code or %USERPROFILE%\.code)
# CODE_HOME=D:\path\to\custom-code-home

# Ollama API
OLLAMA_BASE_URL=http://localhost:11434

# Models (pull first: ollama pull qwen2.5-coder:14b && ollama pull nomic-embed-text)
LLM_MODEL=qwen2.5-coder:14b
EMBED_MODEL=nomic-embed-text
